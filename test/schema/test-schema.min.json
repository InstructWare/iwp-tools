{
  "schema_name": "test",
  "schema_version": "1.0.0",
  "modes": {
    "default": "compat",
    "supported": [
      "compat",
      "strict"
    ]
  },
  "global_rules": {
    "h1_required_exactly_one": true,
    "h2_unknown_policy": {
      "compat": "warn",
      "strict": "error"
    }
  },
  "kind_rules": {
    "format": "{file_type_id}.{section_key}"
  },
  "section_i18n": {
    "layout_tree": {
      "en": [
        "Layout Tree"
      ]
    },
    "interaction_hooks": {
      "en": [
        "Interaction Hooks"
      ]
    }
  },
  "file_type_schemas": [
    {
      "id": "docs",
      "path_patterns": [
        "**/*.md",
        "*.md"
      ],
      "sections": [
        {
          "key": "layout_tree",
          "required": true
        },
        {
          "key": "interaction_hooks",
          "required": false
        }
      ]
    }
  ]
}
