        "styles/*.md"
      ],
      "sections": [
        {
          "key": "brand_intent",
          "required": false
        },
        {
          "key": "theme_tokens",
          "required": true
        },
        {
          "key": "typography",
          "required": false
        },
        {
          "key": "spacing_scale",
          "required": false
        },
        {
          "key": "layout_rules",
          "required": false
        },
        {
          "key": "motion",
          "required": false
        },
        {
          "key": "component_tokens",
          "required": false
        },
        {
          "key": "iconography",
          "required": false
