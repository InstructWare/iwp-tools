  "file_type_schemas": [
    {
      "id": "views.pages",
      "path_patterns": [
        "views/pages/**/*.md",
        "views/pages/*.md"
      ],
      "sections": [
        {
          "key": "layout_tree",
          "required": true
        },
        {
          "key": "interaction_hooks",
          "required": true
        },
        {
          "key": "display_rules",
          "required": false
        },
        {
          "key": "data_bindings",
          "required": false
        },
        {
          "key": "empty_states",
          "required": false
        },
        {
          "key": "accessibility",
          "required": false
        },
        {
          "key": "telemetry",
          "required": false
        }
      ]
    },
    {
      "id": "views.components",
      "path_patterns": [
        "views/components/**/*.md",
        "views/components/*.md"
      ],
      "sections": [
        {
          "key": "layout",
          "required": true
        },
        {
          "key": "interaction_hooks",
          "required": false
        },
        {
          "key": "display_rules",
          "required": false
        },
        {
          "key": "props_contract",
          "required": false
        },
        {
          "key": "slots",
          "required": false
        },
        {
          "key": "accessibility",
