    {
      "id": "system",
      "path_patterns": [
        "system.md"
      ],
      "sections": [
        {
          "key": "product_identity",
          "required": true
        },
        {
          "key": "global_rules",
          "required": true
        },
        {
          "key": "information_architecture",
          "required": true
        },
        {
          "key": "runtime_guarantees",
          "required": true
        },
        {
          "key": "security_model",
          "required": true
        }
      ]
    },
    {
      "id": "architecture",
      "path_patterns": [
        "architecture.md"
      ],
      "sections": [
        {
          "key": "architecture_scope",
          "required": true
        },
        {
          "key": "state_management",
          "required": true
        },
        {
          "key": "rendering_strategy",
          "required": true
        },
        {
          "key": "event_orchestration",
          "required": true
        },
        {
          "key": "dependency_governance",
          "required": false
        },
        {
          "key": "observability",
          "required": false
        },
        {
          "key": "boundary_rules",
          "required": false
        }
      ],
      "allow_unknown_sections": true
    },
    {
      "id": "governance.dependency",
      "path_patterns": [
        "dependency.md"
      ],
      "sections": [
        {
          "key": "purpose",
          "required": true
        },
        {
          "key": "core_rules",
          "required": true
        },
        {
          "key": "boundary_with_manifest",
          "required": false
