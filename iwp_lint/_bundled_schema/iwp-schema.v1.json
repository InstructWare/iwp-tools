          "key": "trigger",
          "required": true
        },
        {
          "key": "input",
          "required": false
        },
        {
          "key": "execution_flow",
          "required": true
        },
        {
          "key": "guard_rules",
          "required": false
        },
        {
          "key": "side_effects",
          "required": false
        },
        {
          "key": "failure_handling",
          "required": false
        },
        {
          "key": "output",
          "required": false
        },
        {
          "key": "post_redirect_rules",
          "required": false
        }
      ]
    },
    {
      "id": "state",
      "path_patterns": [
        "state/*.md"
      ],
      "sections": [
        {
          "key": "fields",
          "required": true
        },
        {
          "key": "ownership",
          "required": false
        },
        {
          "key": "constraints",
          "required": false
        },
        {
          "key": "initialization_rules",
          "required": false
        },
        {
          "key": "update_rules",
          "required": false
        },
        {
          "key": "derivation_rules",
          "required": false
        },
        {
          "key": "runtime_guarantees",
          "required": false
        },
        {
          "key": "persistence",
          "required": false
        }
      ]
    },
    {
      "id": "models",
      "path_patterns": [
        "models/**/*.md"
      ],
      "sections": [
        {
          "key": "purpose",
          "required": false
        },
        {
          "key": "entity",
          "required": true
        },
        {
          "key": "constraints",
          "required": false
        },
        {
          "key": "relations",
          "required": false
        },
        {
          "key": "indexes",
          "required": false
        },
        {
          "key": "seed_data",
          "required": false
        },
        {
          "key": "canonical_extraction_rules",
          "required": false
        },
        {
          "key": "derived_toc_rules",
          "required": false
        }
      ]
