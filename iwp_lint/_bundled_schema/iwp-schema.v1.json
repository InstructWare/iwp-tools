        {
          "key": "current_constraints",
          "required": false
        },
        {
          "key": "selection_policy",
          "required": false
        },
        {
          "key": "security_license_baseline",
          "required": false
        }
      ],
      "allow_unknown_sections": true
    },
    {
      "id": "prompts",
      "path_patterns": [
        "prompts/**/*.md",
        "prompts/*.md"
      ],
      "sections": [
        {
          "key": "objective",
          "required": true
        },
        {
          "key": "input_contract",
          "required": false
        },
        {
          "key": "output_contract",
          "required": false
        },
        {
          "key": "safety_constraints",
          "required": false
        },
        {
          "key": "few_shot",
          "required": false
        }
      ]
    }
  ],
  "linter_error_contract": {
    "IWP201": "missing required section",
    "IWP202": "illegal section for file type",
    "IWP203": "invalid section cardinality",
    "IWP204": "invalid section structure",
    "IWP205": "invalid scenario grammar"
  }
}
