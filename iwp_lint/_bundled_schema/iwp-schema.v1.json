      "path_patterns": [
        "tests/**/*.md"
      ],
      "sections": [
        {
          "key": "scenario",
          "required": true
        },
        {
          "key": "setup",
          "required": false
        },
        {
          "key": "input",
          "required": false
        },
        {
          "key": "assertions",
          "required": false
        },
        {
          "key": "cleanup",
          "required": false
        }
      ]
    },
    {
