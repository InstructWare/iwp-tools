{
  "schema_name": "IWP Semantic Schema",
  "schema_version": "2.0.0",
  "status": "draft",
  "description": "Machine-readable minimal schema for IWP markdown file types.",
  "modes": {
    "default": "compat",
    "supported": [
      "compat",
      "strict"
    ]
  },
  "global_rules": {
    "h1_required_exactly_one": true,
    "h2_unknown_policy": {
      "compat": "warn",
      "strict": "error"
    }
  },
  "kind_rules": {
    "format": "{file_type_id}.{section_key}"
  },
