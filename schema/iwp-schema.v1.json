  "file_type_schemas": [
    {
      "id": "views.pages",
      "path_patterns": [
        "views/pages/**/*.md",
        "views/pages/*.md"
      ],
      "sections": [
        {
          "key": "layout_tree",
          "required": true
        },
        {
          "key": "interaction_hooks",
          "required": true
        },
        {
          "key": "display_rules",
          "required": false
        }
      ]
    },
    {
      "id": "views.components",
      "path_patterns": [
        "views/components/**/*.md",
        "views/components/*.md"
      ],
      "sections": [
        {
          "key": "layout",
          "required": true
        },
        {
          "key": "interaction_hooks",
          "required": true
        },
        {
          "key": "display_rules",
          "required": false
        }
      ]
    },
    {
      "id": "logic",
      "path_patterns": [
        "logic/**/*.md"
      ],
      "sections": [
        {
          "key": "trigger",
          "required": true
        },
        {
          "key": "execution_flow",
          "required": false
        },
        {
          "key": "input",
          "required": false
        },
        {
          "key": "guard_rules",
          "required": false
        },
        {
          "key": "post_redirect_rules",
          "required": false
        }
      ]
    },
    {
      "id": "state",
      "path_patterns": [
        "state/*.md"
      ],
      "sections": [
        {
          "key": "fields",
          "required": true
        },
        {
          "key": "initialization_rules",
          "required": false
        },
        {
          "key": "derivation_rules",
          "required": false
        },
        {
          "key": "update_rules",
          "required": false
        },
        {
          "key": "runtime_guarantees",
          "required": false
        }
      ]
    },
    {
      "id": "models",
      "path_patterns": [
        "models/**/*.md"
      ],
      "sections": [
        {
          "key": "entity",
          "required": true
        },
        {
          "key": "seed_data",
          "required": false
        },
        {
          "key": "purpose",
          "required": false
        },
        {
          "key": "canonical_extraction_rules",
          "required": false
        },
        {
          "key": "derived_toc_rules",
          "required": false
        }
      ]
    },
    {
      "id": "tests",
      "path_patterns": [
        "tests/**/*.md"
      ],
      "sections": [
        {
          "key": "scenario",
          "required": true
        }
      ]
    },
    {
      "id": "locales",
      "path_patterns": [
        "locales/*.md"
      ],
      "sections": [
        {
          "key": "navigation",
          "required": false
        },
        {
          "key": "common_actions",
          "required": false
        },
        {
          "key": "docs",
          "required": false
        },
        {
          "key": "home",
          "required": false
        }
      ]
    },
    {
      "id": "styles",
      "path_patterns": [
        "styles/*.md"
      ],
      "sections": [
        {
          "key": "brand_intent",
          "required": false
        },
        {
          "key": "theme_tokens",
          "required": false
        },
        {
          "key": "typography",
          "required": false
        },
        {
          "key": "layout_rules",
          "required": false
        },
        {
          "key": "spacing_scale",
          "required": false
        }
      ]
    },
    {
      "id": "system",
      "path_patterns": [
        "system.md"
      ],
      "sections": [
        {
          "key": "product_identity",
          "required": true
        },
        {
          "key": "global_rules",
          "required": true
        },
        {
          "key": "information_architecture",
          "required": true
        },
        {
          "key": "runtime_guarantees",
          "required": true
        }
      ]
    },
    {
      "id": "architecture",
      "path_patterns": [
        "architecture.md"
      ],
      "sections": [
        {
          "key": "architecture_scope",
          "required": true
        },
        {
          "key": "state_management",
          "required": true
        },
        {
          "key": "rendering_strategy",
          "required": true
        },
        {
          "key": "event_orchestration",
          "required": true
        },
        {
          "key": "boundary_rules",
          "required": false
        }
      ]
    }
  ],
  "linter_error_contract": {
    "IWP201": "missing required section",
    "IWP202": "illegal section for file type",
    "IWP203": "invalid section cardinality",
    "IWP204": "invalid section structure",
    "IWP205": "invalid scenario grammar"
  }
}

